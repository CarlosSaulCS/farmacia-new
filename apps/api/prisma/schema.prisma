generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ProductKind {
  MEDICATION
  MEDICAL_SUPPLY
  MEDICAL_SERVICE
}

enum FollowUpStatus {
  NONE
  PENDING
  COMPLETED
  CANCELLED
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  OPENING
  SALE
  INCOME
  EXPENSE
  ADJUSTMENT
  CLOSING
}

model Product {
  id                 Int                 @id @default(autoincrement())
  sku                String              @unique
  name               String
  commercialName     String?
  kind               ProductKind         @default(MEDICATION)
  description        String?
  category           String?
  unit               String              @default("unidad")
  cost               Float               @default(0)
  price              Float
  stock              Int                 @default(0)
  minStock           Int                 @default(0)
  expiresAt          DateTime?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  saleItems          SaleItem[]
  inventoryMovements InventoryMovement[]
  costEvents         ProductCostEvent[]
  priceEvents        ProductPriceEvent[]
  lots               InventoryLot[]
  consultations      Consultation[]      @relation("ConsultationServiceProduct")
}

model Sale {
  id           Int        @id @default(autoincrement())
  createdAt    DateTime   @default(now())
  customerName String?
  notes        String?
  subtotal     Float
  discount     Float      @default(0)
  total        Float
  amountPaid   Float?
  changeGiven  Float?
  items        SaleItem[]
  cashMovements CashMovement[]
}

model SaleItem {
  id                    Int          @id @default(autoincrement())
  saleId                Int
  productId             Int
  quantity              Int
  unitPrice             Float
  unitCost              Float        @default(0)
  lineTotal             Float
  productSku            String?
  productName           String?
  productCommercialName String?
  productKind           ProductKind?
  productCategory       String?
  sale                  Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product               Product      @relation(fields: [productId], references: [id])
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Appointment {
  id            Int               @id @default(autoincrement())
  patientId     Int?
  patientName   String
  patientPhone  String?
  serviceType   String
  notes         String?
  appointmentAt DateTime
  status        AppointmentStatus @default(SCHEDULED)
  patient       Patient?          @relation(fields: [patientId], references: [id], onDelete: SetNull)
  consultation  Consultation?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([appointmentAt, status])
  @@index([patientId])
}

model Patient {
  id            Int            @id @default(autoincrement())
  fullName      String
  phone         String?
  notes         String?
  lastVisitAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  appointments  Appointment[]
  consultations Consultation[]

  @@index([fullName])
}

model Consultation {
  id               Int            @id @default(autoincrement())
  patientId        Int
  appointmentId    Int?           @unique
  serviceProductId Int?
  serviceType      String
  summary          String?
  diagnosis        String?
  treatment        String?
  observations     String?
  followUpAt       DateTime?
  followUpStatus   FollowUpStatus @default(NONE)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  patient          Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment      Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  serviceProduct   Product?       @relation("ConsultationServiceProduct", fields: [serviceProductId], references: [id], onDelete: SetNull)

  @@index([patientId, createdAt])
  @@index([followUpAt, followUpStatus])
}

model InventoryMovement {
  id        Int      @id @default(autoincrement())
  productId Int
  change    Int
  reason    String
  lotCode   String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductCostEvent {
  id           Int      @id @default(autoincrement())
  productId    Int
  previousCost Float
  newCost      Float
  changePct    Float
  reason       String
  createdAt    DateTime @default(now())
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductPriceEvent {
  id            Int      @id @default(autoincrement())
  productId     Int
  previousPrice Float
  newPrice      Float
  changePct     Float
  reason        String
  createdAt     DateTime @default(now())
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model InventoryLot {
  id        Int      @id @default(autoincrement())
  productId Int
  lotCode   String
  expiresAt DateTime?
  quantity  Int      @default(0)
  cost      Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, lotCode])
  @@index([productId, expiresAt])
}

model CashSession {
  id             Int               @id @default(autoincrement())
  status         CashSessionStatus @default(OPEN)
  openingAmount  Float             @default(0)
  expectedAmount Float             @default(0)
  countedAmount  Float?
  difference     Float?
  notes          String?
  openedAt       DateTime          @default(now())
  closedAt       DateTime?
  movements      CashMovement[]

  @@index([status, openedAt])
}

model CashMovement {
  id        Int              @id @default(autoincrement())
  sessionId Int
  saleId    Int?
  type      CashMovementType
  amount    Float
  reason    String
  createdAt DateTime         @default(now())
  session   CashSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sale      Sale?            @relation(fields: [saleId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  entityType String
  entityId   Int?
  action     String
  message    String
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, createdAt])
}

model AiSuggestion {
  id             Int      @id @default(autoincrement())
  suggestionType String
  payload        Json
  createdAt      DateTime @default(now())
}
