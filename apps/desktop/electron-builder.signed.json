{
  "appId": "mx.com.codesolutionsstudio.farmacia",
  "productName": "Farmacia",
  "copyright": "Copyright (c) 2026 Code Solutions Studio",
  "directories": {
    "output": "dist",
    "buildResources": "build"
  },
  "files": [
    "main.cjs",
    "package.json",
    "runtime/api/**/*"
  ],
  "asarUnpack": [
    "**/*.node",
    "**/.prisma/**"
  ],
  "extraFiles": [
    {
      "from": "../web/dist",
      "to": "web",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "../api/dist",
      "to": "api/dist",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "../api/prisma",
      "to": "api/prisma",
      "filter": [
        "schema.prisma"
      ]
    },
    {
      "from": "../api/package.json",
      "to": "api/package.json"
    },
    {
      "from": "../../node_modules/@prisma/client",
      "to": "api/node_modules/@prisma/client",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "../../node_modules/.prisma",
      "to": "api/node_modules/.prisma",
      "filter": [
        "**/*"
      ]
    }
  ],
  "win": {
    "icon": "build/icon.png",
    "signtoolOptions": {
      "publisherName": "Code Solutions Studio"
    },
    "signAndEditExecutable": true,
    "verifyUpdateCodeSignature": true,
    "legalTrademarks": "Code Solutions Studio",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "Farmacia-${version}-Setup.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Farmacia"
  }
}
